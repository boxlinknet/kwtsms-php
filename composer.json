{
    "name": "kwtsms/kwtsms-php",
    "description": "kwtSMS API Client for PHP. Official library to interface with the Kuwait SMS gateway (kwtsms.com)",
    "type": "library",
    "keywords": ["kwtsms", "sms", "kuwait", "sms-gateway", "otp", "notification", "messaging"],
    "homepage": "https://github.com/boxlinknet/kwtsms-php",
    "license": "MIT",
    "authors": [
        {
            "name": "M Alhassoun",
            "email": "mo@boxlink.net",
            "homepage": "https://boxlink.net"
        }
    ],
    "support": {
        "issues": "https://github.com/boxlinknet/kwtsms-php/issues",
        "source": "https://github.com/boxlinknet/kwtsms-php"
    },
    "require": {
        "php": ">=7.4",
        "ext-curl": "*",
        "ext-json": "*"
    },
    "require-dev": {
        "friendsofphp/php-cs-fixer": "^3.40",
        "phpstan/phpstan": "^1.10",
        "phpunit/phpunit": "^9.6"
    },
    "autoload": {
        "psr-4": {
            "KwtSMS\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "KwtSMS\\Tests\\": "tests/"
        }
    },
    "scripts": {
        "test": "vendor/bin/phpunit",
        "phpstan": "vendor/bin/phpstan analyse src tests",
        "format": "vendor/bin/php-cs-fixer fix src tests"
    },
    "config": {
        "sort-packages": true
    }
}
