#!/usr/bin/env php
<?php

/**
 * kwtSMS CLI — Send SMS from the command line.
 *
 * Usage:
 *   kwtsms send --phone PHONE --message MESSAGE [--sender SENDERID]
 *   kwtsms verify
 *
 * Reads credentials from .env or environment variables:
 *   KWTSMS_USERNAME, KWTSMS_PASSWORD, KWTSMS_SENDER_ID, KWTSMS_TEST_MODE
 *
 * Examples:
 *   kwtsms send --phone 96598765432 --message "Hello from CLI"
 *   kwtsms send --phone 96598765432 --message "Hello" --sender MY-BRAND
 *   kwtsms verify
 */

require __DIR__ . '/../vendor/autoload.php';

use KwtSMS\KwtSMS;

// ── Parse command ─────────────────────────────────────────────────────────────

$args    = array_slice($argv, 1);
$command = array_shift($args) ?? '';

if ($command === '' || $command === '--help' || $command === '-h') {
    fwrite(STDOUT, cli_usage());
    exit(0);
}

if (!in_array($command, ['send', 'verify'], true)) {
    fwrite(STDERR, "Error: Unknown command '{$command}'.\n\n");
    fwrite(STDERR, cli_usage());
    exit(1);
}

// ── Parse flags ───────────────────────────────────────────────────────────────

$phone   = null;
$message = null;
$sender  = null;

$argCount = count($args);
for ($i = 0; $i < $argCount; $i++) {
    $flag = $args[$i];

    switch ($flag) {
        case '--phone':
            $phone = require_flag_value($args, $i, '--phone', 'e.g. --phone 96598765432');
            break;

        case '--message':
            $message = require_flag_value($args, $i, '--message', 'e.g. --message "Hello world"');
            break;

        case '--sender':
            // --sender without a value would silently consume the next flag as the sender ID
            // (e.g. --sender --phone would set sender="--phone" and lose the phone flag).
            // We catch this explicitly and exit with a clear error.
            $sender = require_flag_value($args, $i, '--sender', 'e.g. --sender MY-BRAND  (omit flag to use KWTSMS_SENDER_ID default)');
            break;

        case '--help':
        case '-h':
            fwrite(STDOUT, cli_usage());
            exit(0);

        default:
            fwrite(STDERR, "Error: Unknown option '{$flag}'.\n\n");
            fwrite(STDERR, cli_usage());
            exit(1);
    }
}

// ── Validate required flags per command ───────────────────────────────────────

if ($command === 'send') {
    if ($phone === null) {
        fwrite(STDERR, "Error: --phone is required for the send command.\n");
        fwrite(STDERR, "       Example: kwtsms send --phone 96598765432 --message \"Hello\"\n");
        exit(1);
    }
    if ($message === null) {
        fwrite(STDERR, "Error: --message is required for the send command.\n");
        fwrite(STDERR, "       Example: kwtsms send --phone 96598765432 --message \"Hello\"\n");
        exit(1);
    }
}

// ── Load client ───────────────────────────────────────────────────────────────

$sms = KwtSMS::from_env();

// ── Execute command ───────────────────────────────────────────────────────────

if ($command === 'verify') {
    [$ok, $balance, $error] = $sms->verify();

    if ($ok) {
        fwrite(STDOUT, "OK\n");
        fwrite(STDOUT, "balance:   {$balance}\n");
        exit(0);
    } else {
        fwrite(STDERR, "ERROR: {$error}\n");
        exit(1);
    }
}

// command === 'send'
$result = $sms->send((string) $phone, (string) $message, $sender);

if ($result['result'] === 'OK') {
    fwrite(STDOUT, "OK\n");
    fwrite(STDOUT, "msg-id:         " . ($result['msg-id']         ?? '') . "\n");
    fwrite(STDOUT, "numbers:        " . ($result['numbers']        ?? '') . "\n");
    fwrite(STDOUT, "points-charged: " . ($result['points-charged'] ?? '') . "\n");
    fwrite(STDOUT, "balance-after:  " . ($result['balance-after']  ?? '') . "\n");

    if (!empty($result['invalid'])) {
        fwrite(STDOUT, "\nRejected numbers:\n");
        foreach ($result['invalid'] as $inv) {
            fwrite(STDOUT, "  - {$inv['number']}: {$inv['error']}\n");
        }
    }
    exit(0);
}

// Error
$code   = (string) ($result['code']        ?? '');
$desc   = (string) ($result['description'] ?? 'Unknown error');
$action = (string) ($result['action']      ?? '');

fwrite(STDERR, "ERROR [{$code}]: {$desc}\n");
if ($action !== '') {
    fwrite(STDERR, "Action: {$action}\n");
}
exit(1);

// ── Helpers ───────────────────────────────────────────────────────────────────

/**
 * Get the value of a CLI flag, or exit with a clear error if none is provided.
 *
 * Catches the specific bug where a flag like --sender is written without a value:
 *   kwtsms send --phone 96598765432 --sender           ← no value, caught here
 *   kwtsms send --phone 96598765432 --sender --message ← next flag consumed as value
 *
 * @param array<int, string> $args
 */
function require_flag_value(array $args, int &$i, string $flag, string $hint): string
{
    $next = $args[$i + 1] ?? '';

    // No next argument at all
    if ($next === '') {
        fwrite(STDERR, "Error: {$flag} requires a value ({$hint}).\n");
        exit(1);
    }

    // Next token is itself a flag (starts with --) — user forgot to supply a value
    if (strpos($next, '--') === 0) {
        fwrite(STDERR, "Error: {$flag} requires a value but got another flag '{$next}'.\n");
        fwrite(STDERR, "       Hint: {$hint}\n");
        exit(1);
    }

    ++$i;
    return $next;
}

function cli_usage(): string
{
    return <<<USAGE
kwtSMS CLI

Usage:
  kwtsms send --phone PHONE --message MESSAGE [--sender SENDERID]
  kwtsms verify
  kwtsms --help

Commands:
  send     Send an SMS message
  verify   Verify credentials and print current balance

Options for send:
  --phone PHONE       Phone number in international format (e.g. 96598765432)
  --message MESSAGE   Message text (emojis and HTML are auto-stripped)
  --sender SENDERID   Override sender ID for this message
                      (default: KWTSMS_SENDER_ID from .env)

Global:
  --help, -h          Show this help

Environment (.env or shell):
  KWTSMS_USERNAME     API username  (required)
  KWTSMS_PASSWORD     API password  (required)
  KWTSMS_SENDER_ID    Default sender ID
  KWTSMS_TEST_MODE    Set to 1 to queue without delivering

Examples:
  kwtsms send --phone 96598765432 --message "Your code is: 123456"
  kwtsms send --phone 96598765432 --message "Hello" --sender MY-BRAND
  kwtsms verify

USAGE;
}
